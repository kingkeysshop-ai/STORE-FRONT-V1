# Medusa.js Storefront - Required Environment Variables
# Get NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY from your Medusa admin: https://docs.medusajs.com/v2/resources/storefront-development/publishable-api-keys

NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_medusa_public_xxx...
MEDUSA_BACKEND_URL=https://your-medusa-backend-domain.com

# Optional: Custom S3 for images (if using Medusa Cloud)
MEDUSA_CLOUD_S3_HOSTNAME=your-s3-domain.com
MEDUSA_CLOUD_S3_PATHNAME=/path/to/bucket/*
