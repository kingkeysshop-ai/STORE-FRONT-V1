# ========================================
# Railway + Medusa Next.js Storefront
# ========================================

# Medusa Backend (Required)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_...
MEDUSA_BACKEND_URL=https://your-medusa-backend.railway.app

# Medusa Storage (Optional - S3)
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=

# Cryptomus Payment (if used)
CRYPTOMUS_API_KEY=your_cryptomus_api_key
CRYPTOMUS_MERCHANT_ID=your_merchant_id

# Next.js (Recommended)
NEXTAUTH_SECRET=your_random_secret_here
NEXTAUTH_URL=https://your-app.railway.app

# Railway auto-provides:
# RAILWAY_ENVIRONMENT=production
# PORT=8000 (handled by package.json)

# Example Railway setup:
# 1. Add these vars in Railway dashboard Variables tab
# 2. MEDUSA_BACKEND_URL → your Medusa backend URL  
# 3. NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY → from Medusa admin
