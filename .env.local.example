# ============================================
# King Keys Storefront - Environment Variables
# ============================================
# Copy this file to `.env.local` and fill in the values.
# .env.local is gitignored.

# ---------- REQUIRED ----------

# URL of your Medusa 2.0 backend (Railway or local)
# Local:
NEXT_PUBLIC_MEDUSA_BACKEND_URL=http://localhost:9000
# Production (Railway):
# NEXT_PUBLIC_MEDUSA_BACKEND_URL=https://king-keys-backend.up.railway.app

# Publishable API key (get from Medusa admin → Settings → Publishable API Keys)
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Default region for the storefront
NEXT_PUBLIC_DEFAULT_REGION=us

# Base URL (used for metadata, sitemap, etc.)
NEXT_PUBLIC_BASE_URL=http://localhost:8000
# Production: NEXT_PUBLIC_BASE_URL=https://king-keys-storefront.up.railway.app

# ---------- OPTIONAL ----------

# Stripe public key (checkout)
NEXT_PUBLIC_STRIPE_KEY=pk_test_xxx

# Server-side Medusa URL (used by Next.js server actions; falls back to public one)
# MEDUSA_BACKEND_URL=http://localhost:9000

# Revalidate secret (optional - for ISR webhooks from Medusa)
REVALIDATE_SECRET=supersecret

# Cryptomus (crypto payments via webhook)
CRYPTOMUS_MERCHANT_ID=
CRYPTOMUS_API_KEY=

# BTCPay Server
BTCPAY_URL=
BTCPAY_STORE_ID=
BTCPAY_API_KEY=

# MinIO/S3 host (for next/image remote patterns)
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
